# ============================================================
# Laravel Docker Platform — Root Environment Variables
# Copy this file to .env and adjust as needed
# ============================================================

# -------------------------------------------------------
# Docker Compose project name (prevents naming collisions
# if you clone this repo into differently-named directories)
# -------------------------------------------------------
COMPOSE_PROJECT_NAME=laravel-docker

# -------------------------------------------------------
# Database
# -------------------------------------------------------
DB_ROOT_PASSWORD=secret
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_PORT=3306

# -------------------------------------------------------
# Redis
# -------------------------------------------------------
REDIS_PORT=6379

# -------------------------------------------------------
# Meilisearch
# -------------------------------------------------------
MEILISEARCH_KEY=masterkey
MEILISEARCH_PORT=7700

# -------------------------------------------------------
# Mail (Mailhog)
# -------------------------------------------------------
MAIL_PORT=1025
MAILHOG_PORT=8025

# -------------------------------------------------------
# Xdebug
# Modes: off | debug | profile | coverage | develop
# Set to "debug" to enable step debugging
# -------------------------------------------------------
XDEBUG_MODE=off
XDEBUG_CLIENT_HOST=host-gateway
