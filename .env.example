COMPOSE_PROJECT_NAME=laravel-docker

DB_ROOT_PASSWORD=secret
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_PORT=3306
REDIS_PORT=6379
MEILISEARCH_KEY=masterkey
MEILISEARCH_PORT=7700
MAIL_PORT=1025
MAILHOG_PORT=8025
XDEBUG_MODE=off
XDEBUG_CLIENT_HOST=host-gateway

# UID/GID remapping — must match your host developer user.
# scripts/setup-dns.sh writes these automatically on first-time setup.
# If you set up manually: run `id -u` and `id -g` on your host to get the values.
# This avoids chmod hacks: PHP-FPM's www-data is remapped to your uid/gid at
# container startup so it owns the project files natively (no git noise).
WWWUSER=1000
WWWGROUP=1000
